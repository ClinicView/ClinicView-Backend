# backend/.env.example — variables para desarrollo local SIN Docker
# Copia como backend/.env y ajusta los valores CHANGE_ME.
# Para Docker Compose usa infra/env/.env.example en su lugar.
#
# Fuente de verdad: backend/src/config/configuration.ts

# Puerto del servidor NestJS (por defecto 3001)
PORT=3001
NODE_ENV=development

# URL del frontend para CORS
FRONTEND_URL=http://localhost:3000

# PostgreSQL local (ajusta usuario, contraseña y nombre de BD)
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/clinica_dev

# Worker IA (sin Docker usa localhost; con Docker usa http://ia:8000)
IA_INTERNAL_URL=http://localhost:8000

# Directorio local donde se guardan los documentos subidos
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=20

# JWT — mínimo 32 caracteres. Genera con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_32_random_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_different_from_above
JWT_REFRESH_EXPIRES_IN=7d

# Admin inicial — leído por `npm run db:seed`
ADMIN_EMAIL=admin@hospital.org
ADMIN_PASSWORD=CHANGE_ME_admin_password_min_8_chars
ADMIN_FULL_NAME=Administrador del Sistema
